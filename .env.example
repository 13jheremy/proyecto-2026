# =======================================
# TALLER DE MOTOS - ENVIRONMENT VARIABLES
# =======================================
# Copiar este archivo como .env y configurar los valores apropiados
# NUNCA commitear el archivo .env real al repositorio
# =======================================

# =========================
# DJANGO CORE SETTINGS
# =========================
SECRET_KEY=your-secret-key-here-generate-a-new-one-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# =========================
# DATABASE CONFIGURATION
# =========================
DB_NAME=taller
DB_USER=root
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306

# =========================
# JWT CONFIGURATION
# =========================
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# =========================
# CLOUDINARY CONFIGURATION
# =========================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =========================
# CORS CONFIGURATION
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-frontend-domain.com

# =========================
# EMAIL CONFIGURATION
# =========================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@tallermotos.com

# =========================
# FRONTEND CONFIGURATION
# =========================
FRONTEND_URL=http://localhost:5173

# =========================
# SECURITY SETTINGS (PRODUCTION)
# =========================
SECURE_SSL_REDIRECT=False

# =========================
# PAGINATION
# =========================
PAGE_SIZE=20

# =========================
# EXAMPLE VALUES FOR DEVELOPMENT
# =========================
# Para desarrollo local, puedes usar estos valores:
# SECRET_KEY=django-insecure-development-key-change-in-production
# DEBUG=True
# ALLOWED_HOSTS=*
# DB_NAME=taller
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
# JWT_ACCESS_TOKEN_MINUTES=60
# JWT_REFRESH_TOKEN_DAYS=7
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# PAGE_SIZE=20
